NODE_ENV=production
PORT=3001

# Endereço público exato do frontend. Separe múltiplos endereços com vírgula.
FRONTEND_ORIGIN=https://painel.seudominio.com.br

JWT_SECRET=gere-um-segredo-longo-aleatorio
JWT_EXPIRES_IN=8h
ALLOW_DEMO_LOGIN=false
MAX_FILE_SIZE_MB=20

DB_HOST=host-mysql-fornecido-pela-locaweb
DB_PORT=3306
DB_USER=usuario-fornecido-pela-locaweb
DB_PASSWORD=senha-do-banco
DB_NAME=nome-do-banco
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Usadas apenas pelo comando npm run create-admin -w backend.
ADMIN_NAME=Administrador Maravilha
ADMIN_EMAIL=admin@maravilhafm.com.br
ADMIN_PASSWORD=troque-por-uma-senha-forte
